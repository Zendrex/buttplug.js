{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"extends": ["ultracite/biome/core"],
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"!**/dist",
			"!**/out",
			"!**/.turbo",
			"!**/.next",
			"!**/.source"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 120,
		"indentWidth": 4
	},
	"linter": {
		"enabled": true,
		"domains": {
			"project": "recommended"
		},
		"rules": {
			"recommended": true,
			"suspicious": {
				"noConsole": "info"
			},
			"performance": {
				"noBarrelFile": "info"
			},
			"correctness": {
				"useExhaustiveDependencies": "info"
			},
			"style": {
				"useImportType": {
					"level": "on",
					"options": { "style": "separatedType" }
				}
			}
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"recommended": true,
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							{
								"type": false,
								"source": [":BUN:", ":NODE:"]
							},
							[":BUN:", ":NODE:"],
							":BLANK_LINE:",
							{
								"type": false,
								"source": [":PACKAGE:"]
							},
							[":PACKAGE:"],
							":BLANK_LINE:",
							{
								"type": false,
								"source": [":ALIAS:"]
							},
							[":ALIAS:"],
							":BLANK_LINE:",
							{
								"type": false,
								"source": [":PATH:"]
							},
							[":PATH:"]
						]
					}
				}
			}
		}
	},
	"javascript": {
		"globals": ["Bun"],
		"formatter": {
			"enabled": true,
			"quoteStyle": "double"
		}
	},
	"json": {
		"parser": {
			"allowComments": true
		},
		"formatter": {
			"enabled": true,
			"indentStyle": "tab"
		}
	}
}
